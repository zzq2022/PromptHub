{
  "name": "@prompthub/db",
  "version": "0.1.0",
  "description": "PromptHub database layer – schema, adapter, and CRUD classes for SQLite",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
