{
  "name": "@prompthub/web",
  "version": "0.7.1",
  "description": "PromptHub Web – self-hosted browser-based prompt management app",
  "license": "AGPL-3.0",
  "private": true,
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "dev:server": "tsx watch src/index.ts",
    "dev:client": "vite",
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "start": "node dist/server/index.js",
    "build:client": "vite build",
    "build:server": "vite build --config vite.server.config.ts",
    "build": "pnpm run build:client && pnpm run build:server",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "lint": "eslint . --ext ts,tsx,mts --report-unused-disable-directives --max-warnings 0",
    "test:smoke": "tsx scripts/smoke.mts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@prompthub/core": "workspace:*",
    "@prompthub/db": "workspace:*",
    "@prompthub/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "fflate": "^0.8.2",
    "hono": "^4.7.4",
    "i18next": "^24.0.0",
    "ipaddr.js": "^2.3.0",
    "jose": "^6.0.11",
    "node-sqlite3-wasm": "^0.8.30",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "^15.0.0",
    "react-router-dom": "^7.14.0",
    "svg-captcha": "^1.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^27.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
