# PromptHub Server Configuration

# Server
PORT=3000
HOST=0.0.0.0

# JWT
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Data directory (SQLite DB + media files)
DATA_DIR=./data

# Registration
# PromptHub Web is intended for a single owner-controlled self-hosted workspace.
# Keep public registration disabled. The first administrator is created via /setup.
ALLOW_REGISTRATION=false

# Logging
LOG_LEVEL=info
